NODE_ENV=production
PORT=3000
HOST=127.0.0.1
MCP_BIND_HOST=127.0.0.1
MCP_ALLOWED_HOSTS=localhost,127.0.0.1
MCP_BEARER_TOKEN=

# rules is lightweight. hybrid/local-gec require the local Python model setup.
CHATPOLISH_PROVIDER=rules
CHATPOLISH_GEC_MODEL=Soyoung97/gec_kr
CHATPOLISH_GEC_TIMEOUT_MS=90000

# Leave empty for fixture/local phrase translation. Set this to the local
# LibreTranslate service URL in Docker Compose.
CHATPOLISH_LIBRETRANSLATE_URL=
CHATPOLISH_LIBRETRANSLATE_TIMEOUT_MS=2200
CHATPOLISH_LIBRETRANSLATE_EXTERNAL_API=0

# Docker production image uses bundled Argos Translate models. Local Node
# development leaves this off unless Python and the models are installed.
CHATPOLISH_ARGOS_ENABLED=0
CHATPOLISH_ARGOS_TIMEOUT_MS=2800

CHATPOLISH_RATE_LIMIT_WINDOW_MS=60000
CHATPOLISH_RATE_LIMIT_MAX=120

# OCR runs locally with Tesseract.js. Language data is downloaded once and cached.
CHATPOLISH_OCR_LANGS=eng,kor,jpn,chi_sim,spa
# Optional. Empty uses Tesseract.js' bundled default language-data URL.
CHATPOLISH_OCR_LANG_PATH=
CHATPOLISH_OCR_CACHE_PATH=.cache/tesseract
CHATPOLISH_OCR_TIMEOUT_MS=120000
CHATPOLISH_OCR_MAX_IMAGE_BYTES=8388608
